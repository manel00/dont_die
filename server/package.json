{
  "name": "godot-mcp-bridge",
  "version": "0.1.0",
  "description": "Custom MCP server to control and query a local Godot bridge over WebSocket",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "setup": "node scripts/setup.mjs",
    "dev": "tsx src/index.ts",
    "prestart": "npm run build && npm run setup",
    "start": "node dist/index.js",
    "prerun": "npm run build && npm run setup",
    "run": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "godot",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
